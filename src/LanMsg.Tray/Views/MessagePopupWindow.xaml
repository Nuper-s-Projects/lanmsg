<Window x:Class="LanMsg.Tray.Views.MessagePopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LanMsg"
        Width="420" MinWidth="320"
        SizeToContent="Height"
        WindowStartupLocation="Manual"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextBrush}">
    <Border Margin="12" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="16">
        <StackPanel>
            <TextBlock x:Name="PriorityBadge" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,8"/>
            <TextBlock x:Name="SenderText" FontSize="16" FontWeight="SemiBold"/>
            <TextBlock x:Name="DeviceText" Foreground="{StaticResource MutedBrush}" FontSize="13" Margin="0,4,0,0"/>
            <TextBlock x:Name="TimeText" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,2,0,12"/>
            <TextBlock x:Name="BodyText" TextWrapping="Wrap" FontSize="15" Margin="0,0,0,12"/>
            <TextBox x:Name="ReplyBox" Visibility="Collapsed" Margin="0,0,0,12" AcceptsReturn="True" MinHeight="60"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Copy" Style="{StaticResource PrimaryBtn}" Margin="0,0,8,0" Click="Copy_Click"/>
                <Button Content="Reply" Style="{StaticResource PrimaryBtn}" Margin="0,0,8,0" Click="Reply_Click"/>
                <Button Content="Close" Style="{StaticResource AccentBtn}" Click="Close_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
