<Window x:Class="LanMsg.Tray.Views.SenderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LanMsg Sender"
        Width="920" Height="640" MinWidth="720" MinHeight="520"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextBrush}">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="12">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Devices" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button Content="Refresh" Style="{StaticResource PrimaryBtn}" Margin="12,0,0,0" Padding="10,6" Click="Refresh_Click"/>
                </StackPanel>
                <ListBox x:Name="DeviceList" Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding Label}" IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="0,4"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>
        <StackPanel Grid.Column="2">
            <TextBlock Text="Send LAN Message" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,12"/>
            <TextBlock Text="Manual host or IP" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
            <TextBox x:Name="ManualHost" Margin="0,0,0,12"/>
            <TextBlock Text="Message" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
            <TextBox x:Name="MessageInput" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="120" Margin="0,0,0,12"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock Text="Priority" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="PriorityBox" Width="160">
                    <ComboBoxItem Content="Normal" IsSelected="True"/>
                    <ComboBoxItem Content="Important"/>
                    <ComboBoxItem Content="Urgent"/>
                </ComboBox>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Button Content="Send" Style="{StaticResource AccentBtn}" Margin="0,0,8,0" Click="Send_Click"/>
                <Button Content="Broadcast" Style="{StaticResource PrimaryBtn}" Margin="0,0,8,0" Click="Broadcast_Click"/>
                <Button Content="Test Message" Style="{StaticResource PrimaryBtn}" Click="Test_Click"/>
            </StackPanel>
            <TextBlock Text="Status log" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
            <Border Background="{StaticResource InputBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="8">
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="220">
                    <TextBox x:Name="LogBox" IsReadOnly="True" Background="Transparent" BorderThickness="0" TextWrapping="Wrap"/>
                </ScrollViewer>
            </Border>
        </StackPanel>
    </Grid>
</Window>
