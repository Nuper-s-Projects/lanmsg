<Window x:Class="LanMsg.Tray.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LanMsg History"
        Width="720" Height="520"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Message History" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,12"/>
        <ListView x:Name="HistoryList" Grid.Row="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Time" DisplayMemberBinding="{Binding Time}" Width="140"/>
                    <GridViewColumn Header="Dir" DisplayMemberBinding="{Binding Direction}" Width="50"/>
                    <GridViewColumn Header="From" DisplayMemberBinding="{Binding From}" Width="160"/>
                    <GridViewColumn Header="Message" DisplayMemberBinding="{Binding Body}" Width="320"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Window>
